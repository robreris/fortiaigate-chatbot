# FortiAIGate endpoint — choose one and set in .env (this file is safe to commit)
#
# Production ALB (internet-facing):
#   FORTIAIGATE_BASE_URL=https://<your-alb-hostname>
#
# Local single-node cluster via make local-proxy (port 9443):
#   FORTIAIGATE_BASE_URL=https://host.docker.internal:9443
#   FORTIAIGATE_SSL_VERIFY=false
#
# Local single-node cluster via make port-forwards (port 28443):
#   FORTIAIGATE_BASE_URL=https://host.docker.internal:28443
#   FORTIAIGATE_SSL_VERIFY=false
#
FORTIAIGATE_BASE_URL=https://<fortiaigate-alb-hostname>

# FortiAIGate gateway API key (Authorization: Bearer)
FORTIAIGATE_API_KEY=<your-faig-api-key>

# Model to route through FortiAIGate AI Flow
FORTIAIGATE_MODEL=gpt-4o-mini

# Set to false when using self-signed certs (local port-forward/proxy scenarios)
FORTIAIGATE_SSL_VERIFY=true

# Basic auth credentials for the web UI
NGINX_USERNAME=demo
NGINX_PASSWORD=<choose-a-password>
